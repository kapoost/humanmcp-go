{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.kapoost/humanmcp",
  "title": "humanMCP — kapoost",
  "description": "Personal MCP server for humans who create. Proof of authorship, license control.",
  "version": "0.3.0",
  "license": "MIT",
  "homepage": "https://humanmcp.net",
  "repository": {
    "url": "https://github.com/kapoost/humanmcp-go",
    "source": "github"
  },
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://kapoost.humanmcp.net/mcp"
    }
  ],
  "tags": [
    "content", "publishing", "authorship", "provenance", "licensing",
    "creative", "personal", "skills", "listings", "marketplace",
    "ask-human", "signatures", "ed25519", "opentimestamps"
  ],
  "capabilities": {
    "public": [
      "get_author_profile", "list_content", "read_content", "search_content",
      "list_skills", "list_listings", "leave_message", "leave_comment",
      "verify_content", "get_certificate", "request_license",
      "ask_human", "about_humanmcp"
    ],
    "authenticated": [
      "bootstrap_session", "query_vault", "list_vault",
      "remember", "recall", "get_persona", "get_skill", "list_personas",
      "get_answer"
    ]
  }
}
